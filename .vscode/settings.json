{
    // Настройки для C/C++
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.cStandard": "c17",
    "C_Cpp.default.intelliSenseMode": "windows-msvc-x64",

    // Исключения из поиска для ускорения работы VS Code
    "files.exclude": {
        "**/.git": true,
        "**/.vs": true,
        "**/*.user": true,
        "**/*.aps": true,
        "**/*.pch": true,
        "**/*.obj": true,
        "**/*.pdb": true
    },

    // Исключения из наблюдения за файлами
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/.vs/**": true,
    },

    // Ассоциации файлов
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.rc": "rc",
        "*.rc2": "rc"
    },

    // Настройки терминала
    "terminal.integrated.defaultProfile.windows": "Command Prompt",

    // Рекомендуемые расширения будут предложены при открытии проекта
    "extensions.ignoreRecommendations": false
}
