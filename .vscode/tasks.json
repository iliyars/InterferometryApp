{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}\\build",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build PipelineTest",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--target", "PipelineTest",
                "--config", "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Rebuild PipelineTest (clean)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--target", "PipelineTest",
                "--config", "Debug",
                "--clean-first"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Debug x64",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Debug"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Release x64",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Release"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}\\build",
                "--config", "Debug",
                "--target", "clean"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
