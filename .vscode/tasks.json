{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug x64",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\InterferometryApp.sln",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m",
                "/v:minimal"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Release x64",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\InterferometryApp.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m",
                "/v:minimal"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build Debug Win32",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\InterferometryApp.sln",
                "/p:Configuration=Debug",
                "/p:Platform=Win32",
                "/m",
                "/v:minimal"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Clean Debug x64",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\InterferometryApp.sln",
                "/t:Clean",
                "/p:Configuration=Debug",
                "/p:Platform=x64"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Rebuild Debug x64",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}\\InterferometryApp.sln",
                "/t:Rebuild",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m"
            ],
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
